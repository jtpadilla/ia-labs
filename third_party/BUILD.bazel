load("@rules_java//java:defs.bzl", "java_import")

package(default_visibility = ["//visibility:public"])

java_library(
    name = "guice_custom_wrapper",
    visibility = ["//visibility:public"],
    # Usamos 'exports' para que quien dependa de esto vea las clases de Guice y ASM
    exports = [
        "@maven//:com_google_inject_guice_classes",  # La versión sin sombrear (unshaded)
        "@maven//:org_ow2_asm_asm",  # ASM nuevo
        "@maven//:org_ow2_asm_asm_tree",
        "@maven//:org_ow2_asm_asm_util",

        # Dependencias que Guice necesita y que solían venir incluidas
        "@maven//:javax_inject_javax_inject",
        "@maven//:aopalliance_aopalliance",
        "@maven//:com_google_guava_guava",
    ],
)

