load("@rules_java//java:defs.bzl", "java_binary", "java_library", "java_plugin")

package(default_visibility = ["//visibility:public"])

java_plugin(
    name = "helidon_codegen_plugin",
    processor_class = "io.helidon.codegen.apt.AptProcessor",
    deps = [
        "@maven//:io_helidon_codegen_helidon_codegen_apt",
        "@maven//:io_helidon_service_helidon_service_codegen",
    ],
)

java_library(
    name = "lib",
    exported_plugins = [
        ":helidon_codegen_plugin",
    ],
    plugins = [
        ":helidon_codegen_plugin",
    ],
    exports = [
        "@maven//:io_helidon_common_helidon_common",
        "@maven//:io_helidon_common_helidon_common_types",
        "@maven//:io_helidon_service_helidon_service_registry",
        "@maven//:jakarta_annotation_jakarta_annotation_api",
        "@maven//:jakarta_inject_jakarta_inject_api",
    ],
)
